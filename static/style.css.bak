/* style.css - 赛博朋克深色主题 */
@import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=Inter:wght@300;400;600;700&display=swap');

:root {
  --bg-dark:    #050b18;
  --bg-panel:   #0a1628;
  --bg-card:    #0f1f3d;
  --accent-1:   #00d4ff;
  --accent-2:   #7c3aed;
  --accent-gold:#FFD700;
  --text-main:  #e2e8f0;
  --text-dim:   #64748b;
  --border:     rgba(0, 212, 255, 0.15);
  --glow:       0 0 20px rgba(0, 212, 255, 0.3);
}

* { margin: 0; padding: 0; box-sizing: border-box; }

body {
  background: var(--bg-dark);
  color: var(--text-main);
  font-family: 'Inter', sans-serif;
  height: 100vh;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

/* ── 顶部 Header ─────────────────────────────────────── */
header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10px 24px;
  background: var(--bg-panel);
  border-bottom: 1px solid var(--border);
  flex-shrink: 0;
  z-index: 10;
}

.logo {
  font-family: 'JetBrains Mono', monospace;
  font-size: 16px;
  font-weight: 700;
  color: var(--accent-1);
  text-shadow: var(--glow);
  letter-spacing: 2px;
}

.logo span { color: var(--accent-gold); }

.header-right { display: flex; align-items: center; gap: 12px; }

.topic-badge {
  background: rgba(124, 58, 237, 0.2);
  border: 1px solid rgba(124, 58, 237, 0.5);
  color: #c4b5fd;
  padding: 4px 12px;
  border-radius: 20px;
  font-size: 12px;
  max-width: 480px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.tick-indicator {
  font-family: 'JetBrains Mono', monospace;
  font-size: 13px;
  color: var(--accent-1);
}

/* ── 控制栏（始终可见） ───────────────────────────────── */
.control-bar {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 24px;
  background: var(--bg-card);
  border-bottom: 1px solid var(--border);
  flex-shrink: 0;
  flex-wrap: wrap;
}

.control-hint {
  font-size: 12px;
  color: var(--text-dim);
  margin-left: 8px;
  flex: 1;
  min-width: 200px;
}

/* ── 主体布局 ─────────────────────────────────────────── */
.main-layout {
  display: flex;
  flex: 1;
  overflow: hidden;
  gap: 0;
}

/* ── ECharts 力导向图区 ──────────────────────────────── */
#graph-container {
  flex: 1;
  position: relative;
  background: radial-gradient(ellipse at center,
    rgba(0, 212, 255, 0.03) 0%,
    var(--bg-dark) 70%);
}

#echarts-graph {
  width: 100%;
  height: 100%;
}

/* 覆叠文字 */
.overlay-hint {
  position: absolute;
  bottom: 20px;
  left: 50%;
  transform: translateX(-50%);
  font-size: 12px;
  color: var(--text-dim);
  font-family: 'JetBrains Mono', monospace;
  pointer-events: none;
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 0.5; }
  50% { opacity: 1; }
}

/* ── 右侧面板 ─────────────────────────────────────────── */
.right-panel {
  width: 360px;
  display: flex;
  flex-direction: column;
  border-left: 1px solid var(--border);
  background: var(--bg-panel);
  flex-shrink: 0;
}

/* 控制区 */
.control-area {
  padding: 16px;
  border-bottom: 1px solid var(--border);
  display: flex;
  gap: 8px;
}

.btn {
  flex: 1;
  padding: 8px 16px;
  border: none;
  border-radius: 6px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 12px;
  cursor: pointer;
  transition: all 0.2s;
  letter-spacing: 1px;
}

.btn-primary {
  background: linear-gradient(135deg, #0ea5e9, var(--accent-2));
  color: #fff;
}

.btn-primary:hover {
  box-shadow: 0 0 15px rgba(0, 212, 255, 0.5);
  transform: translateY(-1px);
}

.btn-primary:disabled {
  opacity: 0.4;
  cursor: not-allowed;
  transform: none;
}

.btn-secondary {
  background: var(--bg-card);
  color: var(--text-dim);
  border: 1px solid var(--border);
}

.btn-secondary:hover { color: var(--accent-1); border-color: var(--accent-1); }

/* Terminal 日志 */
.terminal-header {
  padding: 8px 16px;
  background: var(--bg-card);
  border-bottom: 1px solid var(--border);
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  color: var(--text-dim);
  display: flex;
  align-items: center;
  gap: 8px;
}

.terminal-dot {
  width: 8px; height: 8px;
  border-radius: 50%;
  background: var(--accent-1);
  box-shadow: 0 0 6px var(--accent-1);
  animation: blink 1s infinite;
}

@keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0.2; } }

#terminal-log {
  flex: 1;
  overflow-y: auto;
  padding: 12px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  line-height: 1.8;
  scrollbar-width: thin;
  scrollbar-color: var(--accent-2) transparent;
}

#terminal-log::-webkit-scrollbar { width: 4px; }
#terminal-log::-webkit-scrollbar-thumb { background: var(--accent-2); border-radius: 2px; }

.log-entry { display: flex; gap: 8px; margin-bottom: 2px; }

.log-time { color: var(--text-dim); flex-shrink: 0; }
.log-name { flex-shrink: 0; font-weight: 700; }
.log-speech { color: var(--text-main); }
.log-agree { color: var(--text-dim); font-size: 10px; }

/* ── 部落涌现弹窗 ─────────────────────────────────────── */
#tribe-modal {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(5, 11, 24, 0.85);
  backdrop-filter: blur(8px);
  z-index: 100;
  align-items: center;
  justify-content: center;
}

#tribe-modal.show { display: flex; }

.modal-card {
  background: var(--bg-card);
  border: 1px solid var(--accent-1);
  box-shadow: 0 0 60px rgba(0, 212, 255, 0.2);
  border-radius: 16px;
  padding: 32px;
  max-width: 520px;
  width: 90%;
  text-align: center;
  animation: modalIn 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes modalIn {
  from { opacity: 0; transform: scale(0.8) translateY(20px); }
  to   { opacity: 1; transform: scale(1) translateY(0); }
}

.modal-emoji { font-size: 48px; margin-bottom: 12px; }

.modal-title {
  font-size: 20px;
  font-weight: 700;
  color: var(--accent-gold);
  margin-bottom: 16px;
}

.modal-body { color: var(--text-dim); line-height: 1.7; margin-bottom: 20px; }

.tribe-names {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  justify-content: center;
  margin: 16px 0;
}

.tribe-tag {
  background: rgba(0, 212, 255, 0.1);
  border: 1px solid rgba(0, 212, 255, 0.4);
  color: var(--accent-1);
  padding: 4px 12px;
  border-radius: 20px;
  font-size: 13px;
}

.tribe-tag.human { background: rgba(255, 215, 0, 0.1); border-color: var(--accent-gold); color: var(--accent-gold); }

.modal-actions { display: flex; gap: 12px; justify-content: center; }

.btn-modal-primary {
  background: linear-gradient(135deg, var(--accent-1), var(--accent-2));
  color: #fff;
  padding: 10px 24px;
  border: none;
  border-radius: 8px;
  cursor: pointer;
  font-size: 14px;
  font-weight: 600;
  transition: all 0.2s;
}

.btn-modal-primary:hover { box-shadow: 0 0 20px rgba(0, 212, 255, 0.4); }

.btn-modal-secondary {
  background: transparent;
  color: var(--text-dim);
  padding: 10px 24px;
  border: 1px solid var(--border);
  border-radius: 8px;
  cursor: pointer;
  font-size: 14px;
  transition: all 0.2s;
}

.btn-modal-secondary:hover { color: var(--text-main); }

/* ── 进度条 ─────────────────────────────────────────── */
.progress-bar-container {
  height: 3px;
  background: var(--bg-dark);
  flex-shrink: 0;
}

.progress-bar {
  height: 100%;
  background: linear-gradient(90deg, var(--accent-1), var(--accent-2));
  transition: width 1s ease;
  width: 0%;
}
